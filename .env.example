# 定时任务
ENABLE_SCHEDULER=false

# 数据库配置
# PostgreSQL 连接字符串格式: postgresql://用户名:密码@主机:端口/数据库名?schema=public
DATABASE_URL="postgresql://username:password@localhost:5432/cinex?schema=public"

# 订阅配置
DEFAULT_SUBSCRIBE_MAX_PAGES=100
DEFAULT_SUBSCRIBE_DELAY_MS=1000

# NextAuth 认证配置
# 生成 secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# 代理配置 (可选)
# HTTP_PROXY="http://127.0.0.1:7890"
# HTTPS_PROXY="http://127.0.0.1:7890"

# MetaTube API 配置
METATUBE_API_HOST=https://your-metatube-api-host
METATUBE_API_TOKEN=your-api-token
